# Database
DATABASE_URL=postgresql://postgres:PASSWORD@reseau.proxy.rlwy.net:28313/railway

# Gemini API (screenshot solver)
GEMINI_API_KEY=your_gemini_api_key_from_aistudio

# API Security
API_SECRET=rahasia-dari-desktop-ke-server
PROCESS_SECRET=zomet-secret-2026

# SSO Z One (login desktop). CROSS_APP_SECRET WAJIB sama dengan Z One.
CROSS_APP_SECRET=samakan_dengan_Z_One
NEXT_PUBLIC_ZONE_URL=https://zone.zomet.my.id
# Secret penandatangan token sesi ke desktop (opsional; default = PROCESS_SECRET)
ZSNAP_JWT_SECRET=

# Email (Gmail with App Password)
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password

# Midtrans Payment Gateway (optional)
MIDTRANS_SERVER_KEY=your-midtrans-server-key
MIDTRANS_CLIENT_KEY=your-midtrans-client-key
MIDTRANS_IS_PRODUCTION=false

# Notifications
NOTIFY_TO=your-email@gmail.com
